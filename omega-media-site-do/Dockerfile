FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
ARG VITE_CONTACT_EMAIL
ARG VITE_PHONE_DISPLAY
ARG VITE_WHATSAPP_NUMBER
ARG VITE_FORMSPREE_ENDPOINT
ARG VITE_INSTAGRAM_URL
ARG VITE_FACEBOOK_URL
ENV VITE_CONTACT_EMAIL=$VITE_CONTACT_EMAIL \
    VITE_PHONE_DISPLAY=$VITE_PHONE_DISPLAY \
    VITE_WHATSAPP_NUMBER=$VITE_WHATSAPP_NUMBER \
    VITE_FORMSPREE_ENDPOINT=$VITE_FORMSPREE_ENDPOINT \
    VITE_INSTAGRAM_URL=$VITE_INSTAGRAM_URL \
    VITE_FACEBOOK_URL=$VITE_FACEBOOK_URL
RUN npm run build

FROM nginx:1.27-alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
